class Solution(object):
    def twoSum(self, nums, target):
        temp=[]
        for i in range(0,len(nums)):
            for j in range(i+1,len(nums)):
                if (nums[i]+nums[j]==target):
                    temp=[i,j]
                    return temp
        return temp


