class Solution {
    public List<Integer> findDisappearedNumbers(int[] nums) {
         Set<Integer> seen = new HashSet<>();
        List<Integer> ret = new ArrayList<>();
        
        for (int i : nums) {
            seen.add(i);
        }
        
        for (int i = 1; i <= nums.length; i++) {
            if (!seen.contains(i)) {
                ret.add(i);
            }
        }
        
        return ret;
    
    }
}
